[Unit]
Description=APEX Auto-Trading Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=apexbot
WorkingDirectory=/home/apexbot/apex
ExecStart=/usr/bin/python3 /home/apexbot/apex/bot.py
Restart=always
RestartSec=15
StandardOutput=append:/home/apexbot/apex/trading_bot.log
StandardError=append:/home/apexbot/apex/trading_bot.log

[Install]
WantedBy=multi-user.target
